{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "writer", "admin"] },
        "expertise": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Research writing or data analysis order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "assigned", "in-progress", "completed", "cancelled"] },
        "clientUid": { "type": "string" },
        "writerUid": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientUid", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between client and writer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "senderUid", "text"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders for research help"
    },
    "/orders/{orderId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a specific order"
    }
  }
}
