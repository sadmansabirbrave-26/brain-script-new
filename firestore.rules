rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "sadmansdk@gmail.com");
    }

    function isWriter() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'writer';
    }

    // User Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && request.resource.data.role in ['client', 'writer'];
      allow update: if isOwner(uid) || isAdmin();
    }

    // Order Rules
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.clientUid || 
        request.auth.uid == resource.data.writerUid || 
        isAdmin() ||
        (resource.data.status == 'pending' && isWriter())
      );
      allow create: if isAuthenticated() && request.resource.data.clientUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.clientUid || 
        request.auth.uid == resource.data.writerUid || 
        isAdmin()
      );
      allow delete: if isAdmin() || (request.auth.uid == resource.data.clientUid && resource.data.status in ['pending', 'cancelled']);

      // Message Rules
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.clientUid ||
          request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.writerUid ||
          isAdmin()
        );
        allow create: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.clientUid ||
          request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.writerUid ||
          isAdmin()
        );
      }
    }
  }
}
